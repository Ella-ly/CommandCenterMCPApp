# Public URL of this server (cloudflared / devtunnel). No trailing slash.
SERVER_BASE_URL=http://localhost:8788

# Port the server listens on.
PORT=8788

# Default project shown in the Connect screen.
ADO_PROJECT=MetaOS

# Optional: pre-fill the org in the Connect screen.
ADO_ORG=

# Optional: skip the Connect screen by hard-wiring a PAT here.
# Scopes: Work Items (Read), Code (Read), Build (Read).
ADO_PAT=
